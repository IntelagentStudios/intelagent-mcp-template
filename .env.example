# Environment variables for your MCP server.
#
# Add API keys, credentials, and configuration here.
# This file is safe to commit — it contains no real values.
# Copy to .env and fill in your actual values:
#
#   cp .env.example .env
#
# Example:
# OPENAI_API_KEY=sk-...
# DATABASE_URL=postgresql://localhost:5432/mydb
# LOG_LEVEL=debug
